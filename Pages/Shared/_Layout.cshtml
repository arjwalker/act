<!DOCTYPE html> <html lang="en"> <head> <meta charset="utf-8" /> <meta name="viewport" content="width=device-width, initial-scale=1.0" /> <title>@ViewData["Title"] - SMI Internal ActViewer</title> <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /> <link rel="stylesheet" href="~/css/site-modern-light.css" asp-append-version="true" /> <link rel="stylesheet" href="~/ActViewer.styles.css" asp-append-version="true" /> </head> <body> <!-- Single clean header --> <header class="app-header"> <div class="app-header-inner"> <a class="app-brand" asp-page="/Index">SMI Internal ActViewer</a> <span class="app-pill">Internal</span> <nav class="app-nav"> <a asp-page="/Contacts/Index">Contacts</a> <a asp-page="/Companies/Index">Companies</a> </nav> </div> </header> <!-- Single page container --> <main class="app-container" role="main"> @RenderBody() <div class="app-footer">ActViewer • Internal use</div> </main> <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> <script src="~/js/site.js" asp-append-version="true"></script> @await RenderSectionAsync("Scripts", required: false) </body> </html>